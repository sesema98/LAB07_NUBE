<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Inventario Multi-Instancia</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div>
          <p class="eyebrow">Node.js + Express + SQLite</p>
          <h1>Inventario Multi-Instancia</h1>
        </div>

        <div class="header-meta">
          <span class="port-badge">Backend <%= backendPort %></span>
          <span class="port-badge">Instancia <%= backendInstance %></span>

          <% if (currentUser) { %>
            <div class="user-meta">
              <span>Usuario: <strong><%= currentUser.username %></strong></span>
              <nav class="nav-links">
                <a href="/products">Productos</a>
                <a href="/products/new">Nuevo</a>
              </nav>
            </div>

            <form method="post" action="/logout">
              <button type="submit" class="button secondary">Cerrar sesion</button>
            </form>
          <% } %>
        </div>
      </header>

      <main class="content">
        <%- include('flash') %>
